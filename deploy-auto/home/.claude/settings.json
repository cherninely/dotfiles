    "model": "opus[1m]",
    "hooks": {
        "Notification": [
            {
                "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
                "hooks": [
                    {
                        "type": "command",
                        "command": "afplay /System/Library/Sounds/Glass.aiff",
                        "async": true
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "afplay /System/Library/Sounds/Funk.aiff",
                        "async": true
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "/Users/cherninely/.claude/hooks/rtk-rewrite.sh"
                    }
                ]
            }
        ]
    },
    "enabledPlugins": {
        "typescript-lsp@claude-plugins-official": true,
        "code-simplifier@claude-plugins-official": true,
        "code-review@claude-plugins-official": false
    },
    "disabledMcpServers": [
        "wiki",
        "tracker",
        "yt",
        "monium",
        "infractl",
        "deepagent"
    ],
    "defaultMode": "dontAsk",
    "effortLevel": "max"
}
